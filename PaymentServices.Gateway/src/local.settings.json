{
  "IsEncrypted": false,
  "Values": {
    "AzureWebJobsStorage": "UseDevelopmentStorage=true",
    "FUNCTIONS_WORKER_RUNTIME": "dotnet-isolated",

    // Uncomment and populate for Azure deployment
    // "AZURE_CLIENT_ID": "<user-assigned-managed-identity-client-id>",
    // "AppConfig:Endpoint": "<azure-app-configuration-endpoint>",

    "APPINSIGHTS_INSTRUMENTATIONKEY": "<local-app-insights-key>",
    "APPLICATIONINSIGHTS_CONNECTION_STRING": "<local-app-insights-connection-string>",

    // Cosmos DB — use connection string locally, Managed Identity in Azure
    "app:AppSettings:COSMOS_ENDPOINT": "<cosmos-account-endpoint>",
    "app:AppSettings:COSMOS_CONNSTRING": "<local-cosmos-connection-string>",
    "app:AppSettings:COSMOS_DATABASE": "payments",
    "app:AppSettings:COSMOS_IDEMPOTENCY_CONTAINER": "tch-send-idempotency",
    "app:AppSettings:COSMOS_TRANSACTIONS_CONTAINER": "tch-send-transactions",

    // Service Bus
    "app:AppSettings:SERVICE_BUS_CONNSTRING": "<service-bus-connection-string>",
    "app:AppSettings:SERVICE_BUS_TOPIC": "payment-processing",

    // Gateway-specific
    "app:AppSettings:ALLOWED_FINTECH_IDS": "<fintech-id-1>,<fintech-id-2>,<fintech-id-3>",
    "app:AppSettings:SOURCE_ACCOUNT_NUMBER_PREFIXES": "<prefix-1>,<prefix-2>",

    // Telemetry
    "telemetry:APP_INSIGHTS_CUSTOM_PROP_EVOLVE_TRAIN": "Digital",
    "telemetry:APP_INSIGHTS_CUSTOM_PROP_EVOLVE_TEAM": "Services"
  }
}
