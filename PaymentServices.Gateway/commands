# 1. Create and enter the directory
mkdir PaymentServices.Gateway
cd PaymentServices.Gateway

# 2. Create solution
dotnet new sln -n PaymentServices.Gateway

# 3. Create the Function App project
mkdir src
cd src
dotnet new func --worker-runtime dotnet-isolated --target-framework net10.0 -n PaymentServices.Gateway
cd ..

# 4. Add project to solution
dotnet sln add src/PaymentServices.Gateway.csproj

# 5. Create folder structure
cd src
mkdir Functions
mkdir Services
mkdir Models
mkdir Validators
mkdir Extensions

# 6. Add NuGet packages
dotnet add package Microsoft.Azure.Functions.Worker --version 2.0.0
dotnet add package Microsoft.Azure.Functions.Worker.Sdk --version 2.0.0
dotnet add package Microsoft.Azure.Functions.Worker.Extensions.Http --version 3.3.0
dotnet add package Microsoft.Azure.Functions.Worker.Extensions.Http.AspNetCore --version 2.0.0
dotnet add package Microsoft.Extensions.Configuration.AzureAppConfiguration --version 8.0.0
dotnet add package Azure.Identity --version 1.13.2
dotnet add package Microsoft.Azure.Cosmos --version 3.46.0
dotnet add package Azure.Messaging.ServiceBus --version 7.18.4
dotnet add package Microsoft.ApplicationInsights.WorkerService --version 2.22.0
dotnet add package Microsoft.Azure.Functions.Worker.ApplicationInsights --version 2.0.0
dotnet add package Serilog --version 4.2.0
dotnet add package Serilog.Extensions.Hosting --version 9.0.0
dotnet add package Serilog.Sinks.ApplicationInsights --version 4.0.0
dotnet add package FluentValidation --version 11.11.0
dotnet add package FluentValidation.DependencyInjectionExtensions --version 11.11.0

# 7. Add PaymentServices.Shared — use local reference during development
# before it is published to Azure Artifacts
dotnet add reference ../../PaymentServices.Shared/src/PaymentServices.Shared.csproj

# Once published to Azure Artifacts, switch to NuGet reference instead:
# dotnet add package PaymentServices.Shared --version 1.0.*

# 8. Create deploy_parameters folder structure
cd ..
mkdir -p deploy_parameters/DEV
mkdir -p deploy_parameters/QA
mkdir -p deploy_parameters/PROD
mkdir -p pipelines

# 9. Verify build
cd src && dotnet restore && dotnet build
